# --- Core ---
ENVIRONMENT=development
DATABASE_CONNECTION_STRING=postgresql://user:password@host:5432/dbname?sslmode=require

# --- Security / JWT ---
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
RESET_TOKEN_EXPIRE_MINUTES=60

# --- Google OAuth ---
# Used for Google Sign-In AND the teacher "Connect Google Drive" flow.
GOOGLE_CLIENT_ID=
# Only needed for Drive (the OAuth client secret).
GOOGLE_CLIENT_SECRET=
# Must EXACTLY match an Authorized redirect URI on your OAuth client.
GOOGLE_DRIVE_REDIRECT_URI=http://localhost:8002/api/drive/callback
# Where teachers are sent back after the Drive OAuth round-trip.
FRONTEND_URL=http://localhost:3000

# --- Default admin (created on first startup) ---
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@learningquest.local
ADMIN_PASSWORD=change-me

# --- Email verification ---
APP_NAME=LearningQuest
VERIFICATION_CODE_EXPIRE_MINUTES=15
# SMTP: leave SMTP_HOST blank to log codes to the console (dev mode).
# Gmail example: host smtp.gmail.com, port 587, user = your address,
# password = a Google "App Password" (not your normal password).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_USE_TLS=true

# --- AI quiz import (Groq) ---
# Lets teachers import quiz questions from a PDF/Word file. Free OpenAI-compatible
# key at https://console.groq.com. Leave blank to disable the feature.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# --- CORS (comma-separated; omit to use dev defaults) ---
# CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# Optional regex for extra allowed origins (e.g. your own Vercel project only).
# Leave unset to allow no extra origins. Example:
# CORS_ORIGIN_REGEX=https://your-app-[a-z0-9]+\.vercel\.app

# --- File storage for submission attachments ---
# "local" (default): files saved under static/ and served at /static (dev).
# "gdrive": uploaded into the class teacher's connected Google Drive (a folder
#   per class + per student, Classroom-style). Requires the GOOGLE_* values
#   above plus DRIVE_TOKEN_ENC_KEY below.
STORAGE_BACKEND=local
# Fernet key used to encrypt teacher Drive refresh tokens at rest.
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
DRIVE_TOKEN_ENC_KEY=
